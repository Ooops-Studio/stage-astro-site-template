---
type NavItem = {
  href: string;
  label: string;
  external?: boolean;
};

type Props = {
  brand?: string;
  navItems?: NavItem[];
};

const {
  brand = 'Stage Astro Site',
  navItems = [
    { href: '/', label: 'Home' },
    { href: '/posts', label: 'Posts' },
    { href: 'https://github.com/Ooops-Studio/stage-astro-site-template', label: 'Template', external: true }
  ]
} = Astro.props;
---

<header class="site-header">
  <a class="site-brand" href="/">{brand}</a>
  <nav class="site-nav" aria-label="Primary">
    {navItems.map((item) => (
      <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
</header>
