---
type Props = {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  target?: string;
  rel?: string;
  ariaLabel?: string;
  class?: string;
};

const {
  href,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  disabled = false,
  type = 'button',
  target,
  rel,
  ariaLabel,
  class: className = ''
} = Astro.props;

const classes = ['ui-button', `ui-button-${variant}`, `ui-button-${size}`, fullWidth && 'ui-button-full', className]
  .filter(Boolean)
  .join(' ');

const safeRel = target === '_blank' ? rel || 'noreferrer' : rel;
---

{href ? (
  <a class={classes} href={disabled ? undefined : href} target={target} rel={safeRel} aria-disabled={disabled} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button class={classes} type={type} disabled={disabled} aria-label={ariaLabel}>
    <slot />
  </button>
)}

<style>
  .ui-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: fit-content;
    min-height: var(--button-height);
    padding-inline: var(--button-padding);
    border: 1px solid var(--button-border);
    border-radius: var(--button-radius, 999px);
    background: var(--button-bg);
    color: var(--button-color);
    font: inherit;
    font-size: var(--button-font-size);
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .ui-button:hover {
    transform: translateY(-1px);
  }

  .ui-button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-accent) 32%, transparent);
    outline-offset: 3px;
  }

  .ui-button[disabled],
  .ui-button[aria-disabled='true'] {
    cursor: not-allowed;
    opacity: 0.58;
    transform: none;
  }

  .ui-button-sm {
    --button-height: 36px;
    --button-padding: 14px;
    --button-font-size: 14px;
  }

  .ui-button-md {
    --button-height: 44px;
    --button-padding: 18px;
    --button-font-size: 15px;
  }

  .ui-button-lg {
    --button-height: 52px;
    --button-padding: 22px;
    --button-font-size: 16px;
  }

  .ui-button-full {
    width: 100%;
  }

  .ui-button-primary {
    --button-bg: var(--color-accent);
    --button-border: var(--color-accent);
    --button-color: #fff;
  }

  .ui-button-secondary {
    --button-bg: var(--color-surface);
    --button-border: var(--color-border);
    --button-color: var(--color-text);
  }

  .ui-button-secondary:hover,
  .ui-button-ghost:hover {
    --button-border: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
    --button-color: var(--color-accent);
  }

  .ui-button-ghost {
    --button-bg: transparent;
    --button-border: transparent;
    --button-color: var(--color-text);
  }

  .ui-button-danger {
    --button-bg: #fff0ed;
    --button-border: #f2b9ae;
    --button-color: #af2c1a;
  }
</style>
