---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHome } from '../lib/stage/homepage';

const home = await getHome();
---

<BaseLayout seo={home.seo}>
  <section class="hero">
    <span class="eyebrow">Stage CMS + Astro</span>
    <h1>{home.heading}</h1>
    <p>{home.description}</p>
    <a class="button" href="https://github.com/Ooops-Studio/stage-astro-site-template">Use template</a>
  </section>

  <section class="section" id="backbone">
    <div class="card">
      <span class="meta">Backbone</span>
      <h2>One Stage single type powers this page.</h2>
      <p>
        Add your Stage API token, create a <code>homepage</code> single type, and map
        <code>heading</code>, <code>description</code>, <code>seoTitle</code>, and
        <code>seoDescription</code>.
      </p>
    </div>
  </section>
</BaseLayout>
