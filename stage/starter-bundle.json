{
  "formatVersion": "stage-template-bundle/v1",
  "name": "Stage Astro Site Template Starter",
  "contentTypes": [
    {
      "kind": "single",
      "apiId": "homepage",
      "displayName": "Homepage",
      "description": "Homepage copy and SEO fields for the Astro template.",
      "publicMode": "public_readable",
      "reviewWorkflowMode": "disabled",
      "includeSeoFields": false,
      "fields": [
        {
          "apiId": "heading",
          "displayName": "Heading",
          "kind": "text",
          "isRequired": true
        },
        {
          "apiId": "description",
          "displayName": "Description",
          "kind": "rich_text",
          "isRequired": true
        },
        {
          "apiId": "seo-title",
          "displayName": "SEO title",
          "kind": "text"
        },
        {
          "apiId": "seo-description",
          "displayName": "SEO description",
          "kind": "text"
        },
        {
          "apiId": "canonical-path-override",
          "displayName": "Canonical path override",
          "kind": "text"
        },
        {
          "apiId": "robots-index",
          "displayName": "Robots index",
          "kind": "boolean"
        },
        {
          "apiId": "robots-follow",
          "displayName": "Robots follow",
          "kind": "boolean"
        },
        {
          "apiId": "google-site-verification",
          "displayName": "Google site verification",
          "kind": "text"
        },
        {
          "apiId": "twitter-handle",
          "displayName": "Twitter handle",
          "kind": "text"
        }
      ]
    },
    {
      "kind": "collection",
