        },
        "seo-title": {
          "value": "Stage Astro Site Template",
          "localized": {}
        },
        "seo-description": {
          "value": "A minimal Astro template for public websites powered by Stage CMS.",
          "localized": {}
        },
        "robots-index": {
          "value": true,
          "localized": {}
        },
        "robots-follow": {
          "value": true,
          "localized": {}
        }
      }
    }
  ],
  "collections": [
    {
      "apiId": "posts",
      "entries": [
        {
          "title": "Hello from Stage",
          "slug": "hello-from-stage",
          "publish": true,
          "payload": {
            "title": {
              "value": "Hello from Stage",
              "localized": {}
            },
            "excerpt": {
