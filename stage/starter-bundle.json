      "reviewWorkflowMode": "disabled",
      "hasSlug": true,
      "taggable": true,
      "fields": [
        {
          "apiId": "title",
          "displayName": "Title",
          "kind": "text",
          "isRequired": true,
          "isSearchable": true
        },
        {
          "apiId": "slug",
          "displayName": "Slug",
          "kind": "slug",
          "isRequired": true,
          "isUnique": true,
          "isSortable": true
        },
        {
          "apiId": "excerpt",
          "displayName": "Excerpt",
          "kind": "text"
        },
        {
          "apiId": "body",
          "displayName": "Body",
          "kind": "rich_text",
          "isRequired": true
        },
        {
          "apiId": "seo-title",
          "displayName": "SEO title",
          "kind": "text"
        },
        {
          "apiId": "seo-description",
          "displayName": "SEO description",
          "kind": "text"
        }
      ]
    }
  ],
  "singles": [
    {
      "apiId": "homepage",
      "publish": true,
      "payload": {
        "heading": {
          "value": "Build a Stage-powered Astro site",
